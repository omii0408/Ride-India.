# RideIndia Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# Supabase Project URL (from Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Publishable Key (safe for frontend - replaces anon key)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase Secret Key (BACKEND ONLY - never put in frontend)
SUPABASE_SECRET_KEY=sb_secret_...

# Express server port
PORT=3001
